{
  "name": "@aubron/skill-tools",
  "version": "0.0.0",
  "description": "Validate and release Claude Agent Skills from the @aubron package factory.",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@aubron/eslint-config": "workspace:*",
    "@aubron/prettier-config": "workspace:*",
    "@aubron/tsconfig": "workspace:*",
    "@aubron/tsup-config": "workspace:*",
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "aubron-skill": "./bin/aubron-skill.mjs"
  }
}
