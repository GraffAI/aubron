{
  "name": "@aubron/tsup-config",
  "version": "0.1.0",
  "description": "Shared tsup build preset for @aubron packages.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GraffAI/aubron.git",
    "directory": "packages/tsup-config"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "tsup": "catalog:"
  },
  "devDependencies": {
    "@aubron/eslint-config": "workspace:*",
    "@aubron/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "engines": {
    "node": ">=22"
  }
}
