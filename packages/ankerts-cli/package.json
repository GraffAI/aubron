{
  "name": "@aubron/ankerts-cli",
  "version": "0.1.1",
  "description": "Agent-first CLI for AnkerMake / eufyMake M5 printers — a thin shell over @aubron/ankerts.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GraffAI/aubron.git",
    "directory": "packages/ankerts-cli"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "skills"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aubron/ankerts": "workspace:*"
  },
  "devDependencies": {
    "@aubron/eslint-config": "workspace:*",
    "@aubron/prettier-config": "workspace:*",
    "@aubron/tsconfig": "workspace:*",
    "@aubron/tsup-config": "workspace:*",
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "ankerts": "./dist/index.js"
  }
}
