{
  "name": "@aubron/greet",
  "version": "0.0.0",
  "description": "A tiny example CLI that greets you — proves the @aubron factory end to end.",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@aubron/eslint-config": "workspace:*",
    "@aubron/prettier-config": "workspace:*",
    "@aubron/tsconfig": "workspace:*",
    "@aubron/tsup-config": "workspace:*",
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "greet": "./dist/index.js"
  }
}
